{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "categories": {
        "correctness": "warn",
        "perf": "warn",
        "pedantic": "error"
    },
    "env": {
        "builtin": true,
        "browser": true,
        "node": true
    },
    "ignorePatterns": [
        "**/node_modules/",
        "**/.git/",
        ".next/**",
        ".velite/**",
        "out/**",
        "build/**",
        "next-env.d.ts",
        "pnpm-lock.yaml"
    ],
    "options": {
        "reportUnusedDisableDirectives": "warn",
        "typeAware": true,
        "typeCheck": true
    },
    "plugins": [
        "eslint",
        "typescript",
        "nextjs",
        "react",
        "jsx-a11y",
        "oxc",
        "jsdoc"
    ],
    "jsPlugins": [
        "@stylistic/eslint-plugin",
        { "name": "react-eslint", "specifier": "eslint-plugin-react" },
        { "name": "react-compiler", "specifier": "eslint-plugin-react-hooks" },
        "eslint-plugin-tailwindcss",
        "eslint-plugin-simple-import-sort",
        "@limegrass/eslint-plugin-import-alias",
        "@eslint/css"
    ],
    "rules": {
        //* Built-in
        "no-unused-vars": [
            "warn",
            {
                "args": "all",
                "argsIgnorePattern": "^_",
                "caughtErrorsIgnorePattern": "^_",
                "destructuredArrayIgnorePattern": "^_",
                "varsIgnorePattern": "^_"
            }
        ],
        "max-depth": "off",
        "max-lines": "off",
        "max-lines-per-function": "off",
        "no-inline-comments": "off",
        "prefer-tag-over-role": "off",
        "object-shorthand": "warn",

        //* TypeScript
        // recommended
        "typescript/ban-ts-comment": "warn",
        "typescript/no-empty-object-type": "warn",
        "typescript/no-explicit-any": "warn",
        "typescript/no-misused-promises": "warn",
        "typescript/no-namespace": "warn",
        "typescript/no-require-imports": "warn",
        "typescript/no-unnecessary-type-assertion": "warn",
        "typescript/no-unnecessary-type-constraint": "warn",
        "typescript/no-unsafe-argument": "warn",
        "typescript/no-unsafe-assignment": "warn",
        "typescript/no-unsafe-call": "warn",
        "typescript/no-unsafe-enum-comparison": "warn",
        "typescript/no-unsafe-function-type": "warn",
        "typescript/no-unsafe-member-access": "warn",
        "typescript/no-unsafe-return": "warn",
        "typescript/no-unused-expressions": "warn",
        "typescript/only-throw-error": "warn",
        "typescript/prefer-promise-reject-errors": "warn",
        "typescript/require-await": "warn",
        "typescript/restrict-plus-operands": "warn",
        // strict
        "typescript/no-confusing-void-expression": "warn",
        "typescript/no-deprecated": "warn",
        "typescript/no-dynamic-delete": "warn",
        "typescript/no-extraneous-class": "warn",
        "typescript/no-mixed-enums": "warn",
        "typescript/no-non-null-asserted-nullish-coalescing": "warn",
        "typescript/no-non-null-assertion": "warn",
        "typescript/no-unnecessary-boolean-literal-compare": "warn",
        "typescript/no-unnecessary-condition": "warn",
        "typescript/no-unnecessary-template-expression": "warn",
        "typescript/no-unnecessary-type-arguments": "warn",
        "typescript/no-unnecessary-type-conversion": "warn",
        "typescript/no-unnecessary-type-parameters": "warn",
        "typescript/no-useless-constructor": "warn",
        "typescript/no-useless-default-assignment": "warn",
        "typescript/prefer-literal-enum-member": "warn",
        "typescript/prefer-reduce-type-parameter": "warn",
        "typescript/prefer-return-this-type": "warn",
        "typescript/return-await": "warn",
        "typescript/unified-signatures": "warn",
        "typescript/use-unknown-in-catch-callback-variable": "warn",
        // stylistic
        "typescript/adjacent-overload-signatures": "warn",
        "typescript/array-type": "warn",
        "typescript/ban-tslint-comment": "warn",
        "typescript/class-literal-property-style": "warn",
        "typescript/consistent-generic-constructors": "warn",
        "typescript/consistent-indexed-object-style": "warn",
        "typescript/consistent-type-assertions": "warn",
        "typescript/consistent-type-definitions": "warn",
        "typescript/dot-notation": "warn",
        "typescript/no-confusing-non-null-assertion": "warn",
        "typescript/no-empty-function": "warn",
        "typescript/no-inferrable-types": "warn",
        "typescript/no-invalid-void-type": "warn",
        "typescript/non-nullable-type-assertion-style": "warn",
        "typescript/prefer-find": "warn",
        "typescript/prefer-for-of": "warn",
        "typescript/prefer-function-type": "warn",
        "typescript/prefer-includes": "warn",
        "typescript/prefer-nullish-coalescing": "warn",
        "typescript/prefer-optional-chain": "warn",
        "typescript/prefer-regexp-exec": "warn",

        "typescript/consistent-type-exports": "warn",
        "typescript/prefer-readonly-parameter-types": "off",

        //* Stylistic
        "@stylistic/quotes": [
            "warn",
            "double",
            // const backtick = `backtick` -> "backtick"
            {
                "avoidEscape": true,
                "allowTemplateLiterals": "avoidEscape"
            }
        ]
    },
    "overrides": [
        {
            "files": ["**/*.{ts,tsx}"],
            "rules": {
                "no-empty-function": "off",

                //* TypeScript
                "typescript/strict-boolean-expressions": "off",
                "typescript/unbound-method": "off",
                // "typescript/consistent-type-imports": [
                //     "warn",
                //     { "fixStyle": "inline-type-imports" }
                // ],

                //* React
                "react/no-unknown-property": [
                    "warn",
                    {
                        "ignore": [
                            "tw",
                            "vaul-drawer-wrapper",
                            "cmdk-input-wrapper"
                        ]
                    }
                ],
                "react/no-array-index-key": "off",
                "react-eslint/no-deprecated": "error",

                //* React Compiler
                "react-compiler/config": "error",
                "react-compiler/error-boundaries": "error",
                "react-compiler/component-hook-factories": "error",
                "react-compiler/gating": "error",
                "react-compiler/globals": "error",
                "react-compiler/immutability": "error",
                "react-compiler/preserve-manual-memoization": "error",
                "react-compiler/purity": "error",
                "react-compiler/refs": "error",
                "react-compiler/set-state-in-effect": "error",
                "react-compiler/set-state-in-render": "error",
                "react-compiler/static-components": "error",
                "react-compiler/unsupported-syntax": "warn",
                "react-compiler/use-memo": "error",
                "react-compiler/incompatible-library": "warn",

                //* Tailwind CSS
                "tailwindcss/enforces-shorthand": "warn", // mx-5 my-5 should become m-5
                "tailwindcss/no-custom-classname": "warn",
                "tailwindcss/no-contradicting-classname": "warn", // avoid p-2 p-3
                "tailwindcss/no-unnecessary-arbitrary-value": "warn", // replacing m-[1.25rem] with m-5

                //* Import
                "simple-import-sort/exports": "warn",
                "@limegrass/import-alias/import-alias": [
                    "warn",
                    {
                        "isAllowBaseUrlResolvedImport": false,
                        "aliasConfigPath": "./tsconfig.json"
                    }
                ]
            }
        },
        {
            "files": ["**/*.css"],
            "rules": {
                "@eslint/css/no-duplicate-imports": "error",
                "@eslint/css/use-baseline": "warn",
                "@eslint/css/use-layers": "warn"
            }
        }
    ],
    "settings": {
        "react": {
            "version": "19.2.7"
        },
        "tailwindcss": {
            "callees": ["cn", "cva", "twg", "twMerge"],
            "config": "tailwind.config.ts",
            "cssFiles": [
                "**/*.css",
                "!**/node_modules",
                "!**/.*",
                "!**/dist",
                "!**/build"
            ],
            "cssFilesRefreshRate": 5000,
            "removeDuplicates": false,
            "skipClassAttribute": false,
            "tags": [],
            "classRegex": "^(class(Name)?|containerClassName|tw)$"
        }
    }
}

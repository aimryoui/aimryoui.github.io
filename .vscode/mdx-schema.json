{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Project MDX Frontmatter",
    "type": "object",
    "required": ["projectName", "category", "information", "detail"],
    "properties": {
        "projectName": { "type": "string", "description": "Tên dự án" },
        "category": { "type": "string", "description": "Thể loại dự án" },
        "tools": {
            "type": "array",
            "description": "Các công cụ sử dụng",
            "items": {
                "type": "string",
                "enum": [
                    "figma",
                    "photoshop",
                    "illustrator",
                    "inDesign",
                    "afterEffects",
                    "premierePro",
                    "dreamweaver",
                    "xd",
                    "dimension",
                    "blender"
                ]
            }
        },
        "information": {
            "type": "object",
            "properties": {
                "newest": { "type": "boolean" },
                "duration": { "type": "string" },
                "subject": { "type": "string" },
                "place": { "type": "string" }
            }
        },
        "detail": {
            "type": "object",
            "properties": {
                "description": { "type": "string" },
                "abbreviation": { "type": "string" }
            }
        }
    }
}

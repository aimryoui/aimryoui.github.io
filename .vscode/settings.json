{
    //* General
    "files.eol": "\n",
    "git.followTagsWhenSync": true,
    "prettier.useEditorConfig": false,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "never",
        "source.addMissingImports": "explicit",
        "source.removeUnusedImports": "never",
        "source.fixAll.eslint": "explicit",
        "source.fixAll.stylelint": "explicit",
        //* Biome
        "source.action.noDuplicateClasses.biome": "explicit",
        "source.organizeImports.biome": "explicit",
        "source.fixAll.biome": "explicit"
    },
    "editor.quickSuggestions": {
        "strings": "on"
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "[mdx]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.formatOnSave": true,
    //* Tailwind CSS
    "files.associations": {
        "*.css": "tailwindcss"
    },
    "tailwindCSS.experimental.configFile": "tailwind.config.ts",
    "tailwindCSS.lint.suggestCanonicalClasses": "warning",
    "tailwindCSS.classFunctions": ["cva", "cn", "twg", "twMerge"],
    "tailwindCSS.emmetCompletions": true,
    "tailwindCSS.classAttributes": ["className", "containerClassName", "tw"],
    // CSS REM
    "cssrem.languages": [
        "html",
        "css",
        "tailwindcss", // Add Tailwind CSS
        "javascriptreact",
        "typescriptreact",
        "javascript",
        "typescript"
    ],
    "cssrem.vw": true,
    "cssrem.vwDesign": 1707.33,
    //* TypeScript Version
    "typescript.tsdk": "node_modules\\typescript\\lib"
}

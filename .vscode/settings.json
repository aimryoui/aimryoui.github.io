{
    //* General
    "files.eol": "\n",
    "git.followTagsWhenSync": true,
    "prettier.useEditorConfig": false,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "never",
        "source.addMissingImports": "explicit",
        "source.removeUnusedImports": "never",
        "source.fixAll.eslint": "explicit",
        "source.fixAll.stylelint": "explicit",
        //* Oxc
        "source.fixAll.oxc": "explicit",
        //* Biome
        "source.action.noDuplicateClasses.biome": "explicit",
        "source.organizeImports.biome": "explicit",
        "source.fixAll.biome": "explicit"
    },
    "editor.quickSuggestions": {
        "strings": "on"
    },
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    //* Oxc
    "oxc.enable.oxlint": true,
    "oxc.configPath": ".oxlintrc.json",
    "oxc.enable.oxfmt": true,
    "oxc.fmt.configPath": ".oxfmtrc.json",
    "oxc.requireConfig": true,
    "oxc.disableNestedConfig": true,
    "oxc.tsConfigPath": "tsconfig.json",
    // "oxc.typeAware": true,
    "oxc.fixKind": "safe_fix_or_suggestion",
    "oxc.trace.server": "off",
    //* Tailwind CSS
    "files.associations": {
        "*.css": "tailwindcss"
    },
    "tailwindCSS.experimental.configFile": "tailwind.config.ts",
    "tailwindCSS.lint.suggestCanonicalClasses": "warning",
    "tailwindCSS.classFunctions": ["cva", "cn", "twg", "twMerge"],
    "tailwindCSS.emmetCompletions": true,
    "tailwindCSS.classAttributes": ["className", "containerClassName", "tw"],
    // CSS REM
    "cssrem.languages": [
        "html",
        "css",
        "tailwindcss", // Add Tailwind CSS
        "javascriptreact",
        "typescriptreact",
        "javascript",
        "typescript"
    ],
    "cssrem.vw": true,
    "cssrem.vwDesign": 1707.33,
    //* TypeScript Version
    "typescript.tsdk": "node_modules\\typescript\\lib"
}

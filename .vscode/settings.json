{
    //* General
    "git.followTagsWhenSync": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.fixAll.oxc": "always",
        "source.fixAll.stylelint": "explicit",
        "source.organizeImports": "never",
        "source.addMissingImports": "explicit"
    },
    "editor.quickSuggestions": {
        "strings": "on"
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    //* Oxc
    "oxc.enable.oxlint": true,
    "oxc.configPath": ".oxlintrc.json",
    "oxc.enable.oxfmt": false,
    "oxc.fmt.configPath": ".oxfmtrc.json",
    "oxc.requireConfig": true,
    "oxc.disableNestedConfig": true,
    "oxc.tsConfigPath": "tsconfig.json",
    "oxc.typeAware": true,
    "oxc.fixKind": "safe_fix_or_suggestion",
    "oxc.trace.server": "verbose",
    //* Tailwind CSS
    "files.associations": {
        "*.css": "tailwindcss"
    },
    "tailwindCSS.experimental.configFile": "tailwind.config.ts",
    "tailwindCSS.classFunctions": ["cva", "cn", "twg", "twMerge"],
    "tailwindCSS.emmetCompletions": true,
    "tailwindCSS.classAttributes": ["className", "containerClassName", "tw"],
    // CSS REM
    "cssrem.languages": [
        "html",
        "vue",
        "css",
        "tailwindcss",
        "postcss",
        "less",
        "scss",
        "sass",
        "stylus",
        "tpl",
        "wxss",
        "twig",
        "javascriptreact",
        "typescriptreact",
        "javascript",
        "typescript"
    ],
    "cssrem.vw": true,
    "cssrem.vwDesign": 1707.33,
    //* TypeScript Version
    "typescript.tsdk": "node_modules\\typescript\\lib"
}

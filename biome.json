{
    "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
    "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
    "files": { "ignoreUnknown": false },
    "formatter": {
        "enabled": false
    },
    "linter": {
        "enabled": true,
        "domains": {
            "react": "recommended",
            "types": "recommended"
        },
        "rules": {
            "recommended": true,
            "performance": "on",
            "style": {
                "useImportType": {
                    "level": "warn",
                    "options": { "style": "inlineType" }
                },
                "useExportType": "on"
            }
        },
        "includes": [
            "**",
            "!**/node_modules/",
            "!**/.git/",
            "!**/.next/",
            "!**/.velite/",
            "!**/out/",
            "!**/dist/",
            "!next-env.d.ts",
            "!pnpm-lock.yaml"
        ]
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "overrides": [
        {
            "includes": ["**/*.{ts,tsx}"],
            "linter": {
                "rules": {
                    "correctness": {
                        "noUnusedImports": {
                            "level": "on",
                            "fix": "safe"
                        }
                    },
                    "performance": { "useSolidForComponent": "off" },
                    "complexity": {
                        "useLiteralKeys": {
                            "level": "on",
                            "fix": "safe"
                        }
                    },
                    "suspicious": {
                        "noArrayIndexKey": "off",
                        "noGlobalIsNan": {
                            "level": "on",
                            "fix": "safe"
                        },
                        "useAwait": "on"
                    },
                    "a11y": { "noSvgWithoutTitle": "off" },
                    "style": {
                        "useConsistentArrayType": {
                            "level": "on",
                            "fix": "safe"
                        },
                        "useTemplate": {
                            "level": "on",
                            "fix": "safe"
                        },
                        "noInferrableTypes": "on",
                        "noNamespace": "on",
                        "noNonNullAssertion": {
                            "level": "on",
                            "fix": "safe"
                        },
                        "noCommonJs": "on",
                        "useThrowOnlyError": "on",
                        "useAsConstAssertion": "on",
                        "useForOf": "on"
                    }
                }
            }
        },
        {
            "includes": ["**/*.css"],
            "linter": {
                "rules": {
                    "correctness": {
                        "noUnknownProperty": {
                            "level": "on",
                            "options": {
                                "ignore": ["corner-shape"]
                            }
                        },
                        "noUnknownFunction": {
                            "level": "on",
                            "options": {
                                "ignore": ["superellipse"]
                            }
                        }
                    },
                    "suspicious": {
                        "noUnknownAtRules": {
                            "level": "on",
                            "options": {
                                "ignore": ["tailwind"]
                            }
                        }
                    }
                }
            }
        }
    ],
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "noDuplicateClasses": "on",
                "useSortedProperties": "on",
                "organizeImports": {
                    "level": "on",
                    "options": {
                        "groups": [
                            ":URL:",
                            ":BLANK_LINE:",
                            ":NODE:",
                            ":BLANK_LINE:",
                            "react",
                            ["next", "next/**", "!next-*"],
                            ":BLANK_LINE:",
                            ":PACKAGE:",
                            ":BLANK_LINE:",
                            [":ALIAS:", "!~/**"],
                            ":BLANK_LINE:",
                            "~/**",
                            ":BLANK_LINE:",
                            ":PATH:"
                        ]
                    }
                }
            }
        }
    }
}

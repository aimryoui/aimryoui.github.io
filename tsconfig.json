{
    "compilerOptions": {
        "target": "es2017",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "~/*": ["./*"],
            "@/*": ["./src/*", "./public/*", "./src/app/*"],
            "/*": ["./private/*"]
        }
    },
    "mdx": {
        "checkMdx": true
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        "**/*.mdx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts",
        "src/types/**/*.d.ts"
    ],
    "exclude": ["node_modules", "out", ".next", ".velite", ".vscode", ".git"]
}
